# ============================================
# AppForge Backend — Environment Variables
# ============================================
# Copy this to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/appforge
# OR individual fields:
DB_USER=postgres
DB_PASSWORD=1234
DB_DATABASE=appforge
DB_HOST=localhost
DB_PORT=5432

# Firebase Admin SDK (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Email (Nodemailer — Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=AppForge <your_email@gmail.com>

# GitHub (for export feature)
GITHUB_TOKEN=ghp_your_github_personal_access_token
